{
  "manifest_version": 3,
  "name": "Freshworks Pricing Currency Switcher",
  "version": "1.0.0",
  "description": "View Freshworks pricing in USD, INR, EUR, GBP, or AUD — reads data already embedded in the page.",
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["https://www.freshworks.com/*/pricing/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Freshworks Currency Switcher",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
